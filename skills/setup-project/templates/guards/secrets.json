{
  "description": "Protect .env and secrets/ files from full overwrite",
  "detect": "file:.env OR dir:secrets/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-secrets.sh" }]
      }
    ]
  },
  "script": "guard-secrets.sh"
}
