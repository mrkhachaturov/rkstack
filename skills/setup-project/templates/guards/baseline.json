{
  "description": "Universal destructive command protection (rm -rf, force-push, drop table, etc.)",
  "always": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-destructive.sh", "statusMessage": "Checking for destructive commands..." }]
      }
    ]
  },
  "script": "guard-destructive.sh"
}
