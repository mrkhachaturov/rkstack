{
  "description": "Block direct tofu/terraform commands (require project wrapper)",
  "detect": "stack.terraform",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-terraform.sh" }]
      }
    ]
  },
  "script": "guard-terraform.sh"
}
