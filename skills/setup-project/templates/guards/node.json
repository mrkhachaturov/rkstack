{
  "description": "Guard npm publish, protect lockfiles from full overwrite",
  "detect": "PROJECT_TYPE=node OR PROJECT_TYPE=web",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-destructive.sh" }]
      }
    ]
  },
  "permissions": {
    "deny": ["Bash(npm publish *)"]
  },
  "script": null
}
