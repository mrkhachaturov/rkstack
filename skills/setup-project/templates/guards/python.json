{
  "description": "Guard dangerous Python patterns (eval/exec in commands)",
  "detect": "stack.python",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-python.sh" }]
      }
    ]
  },
  "script": "guard-python.sh"
}
