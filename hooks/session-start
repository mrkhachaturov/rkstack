#!/usr/bin/env bash
# SessionStart hook for rkstack plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# === Binary bootstrap (Claude Code only) ===
# CLAUDE_PLUGIN_DATA and CLAUDE_PLUGIN_ROOT are exported by Claude Code to hook
# processes. They are NOT available inside Claude's Bash tool, so the bootstrap
# must happen here — not in the preamble.
RKSTACK_BOOTSTRAP_RESULT=""
BROWSE_BOOTSTRAP_RESULT=""
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ] && [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  WANT_VERSION=$(cat "${CLAUDE_PLUGIN_ROOT}/VERSION" 2>/dev/null || echo "")
  OS=$(uname -s | tr '[:upper:]' '[:lower:]')
  ARCH=$(uname -m)
  mkdir -p "${CLAUDE_PLUGIN_DATA}/bin"

  if [ -n "$WANT_VERSION" ]; then
    # --- rkstack binary ---
    RKSTACK_BIN="${CLAUDE_PLUGIN_DATA}/bin/rkstack"
    if [ -x "$RKSTACK_BIN" ] && [ "$("$RKSTACK_BIN" version 2>/dev/null)" = "$WANT_VERSION" ]; then
      RKSTACK_BOOTSTRAP_RESULT="RKSTACK_BIN=${RKSTACK_BIN} (v${WANT_VERSION})"
    else
      ASSET="rkstack-${OS}-${ARCH}"
      URL="https://github.com/mrkhachaturov/rkstack/releases/download/v${WANT_VERSION}/${ASSET}"
      FAIL_MARKER="${CLAUDE_PLUGIN_DATA}/bin/.download-failed"
      find "${CLAUDE_PLUGIN_DATA}/bin" -name ".download-failed" -mmin +60 -delete 2>/dev/null || true
      if [ -f "$FAIL_MARKER" ]; then
        RKSTACK_BOOTSTRAP_RESULT="RKSTACK_BIN=UNAVAILABLE (download failed recently, will retry next session)"
      else
        TMPBIN="${RKSTACK_BIN}.tmp.$$"
        if curl --connect-timeout 5 --max-time 30 -fsSL "$URL" -o "$TMPBIN" 2>/dev/null \
           && chmod +x "$TMPBIN" \
           && [ "$("$TMPBIN" version 2>/dev/null)" = "$WANT_VERSION" ]; then
          mv -f "$TMPBIN" "$RKSTACK_BIN"
          rm -f "$FAIL_MARKER"
          RKSTACK_BOOTSTRAP_RESULT="RKSTACK_BIN=${RKSTACK_BIN} (v${WANT_VERSION}, just downloaded)"
        else
          rm -f "$TMPBIN"
          touch "$FAIL_MARKER"
          RKSTACK_BOOTSTRAP_RESULT="RKSTACK_BIN=UNAVAILABLE (download failed or platform ${OS}-${ARCH} not supported)"
        fi
      fi
    fi

    # --- rkstack-browse ---
    # The browse daemon spawns server.ts as a separate process, so it must
    # run from the source tree (where server.ts lives next to cli.ts).
    # We create a thin wrapper script that invokes bun on the source.
    BROWSE_CLI="${CLAUDE_PLUGIN_ROOT}/browse/src/cli.ts"
    RKSTACK_BROWSE="${CLAUDE_PLUGIN_DATA}/bin/rkstack-browse"
    if [ -f "$BROWSE_CLI" ] && command -v bun >/dev/null 2>&1; then
      # Write wrapper script (recreated each session to pick up plugin updates)
      cat > "$RKSTACK_BROWSE" <<WRAPPER
#!/usr/bin/env bash
exec bun "$BROWSE_CLI" "\$@"
WRAPPER
      chmod +x "$RKSTACK_BROWSE"
      BROWSE_BOOTSTRAP_RESULT="RKSTACK_BROWSE=${RKSTACK_BROWSE}"
    else
      BROWSE_BOOTSTRAP_RESULT="RKSTACK_BROWSE=UNAVAILABLE (bun or browse source not found)"
    fi
  fi
fi

# === Project type detection ===
PROJECT_TYPE_RESULT=""
if command -v scc >/dev/null 2>&1; then
  _SCC=$(scc --format wide --no-cocomo --exclude-dir node_modules,.git,vendor,3rdparty-src . 2>/dev/null | head -20)

  _HAS_TS=$(echo "$_SCC" | grep -qi "TypeScript" && echo "yes" || echo "no")
  _HAS_JS=$(echo "$_SCC" | grep -qi "JavaScript" && echo "yes" || echo "no")
  _HAS_CSS=$(echo "$_SCC" | grep -qi "CSS\|SCSS\|SASS\|HTML" && echo "yes" || echo "no")
  _HAS_PY=$(echo "$_SCC" | grep -qi "Python" && echo "yes" || echo "no")
  _HAS_GO=$(echo "$_SCC" | grep -qi "^Go " && echo "yes" || echo "no")
  _HAS_TF=$(echo "$_SCC" | grep -qi "Terraform\|HCL" && echo "yes" || echo "no")

  # Web framework config files
  _HAS_WEB_CONFIG="no"
  for f in next.config.* vite.config.* nuxt.config.* svelte.config.* angular.json; do
    if ls $f 1>/dev/null 2>&1; then _HAS_WEB_CONFIG="yes"; break; fi
  done

  # Classification rules (order matters — first match wins)
  if [ "$_HAS_TS" = "yes" ] || [ "$_HAS_JS" = "yes" ]; then
    if [ "$_HAS_CSS" = "yes" ] || [ "$_HAS_WEB_CONFIG" = "yes" ]; then
      PROJECT_TYPE_RESULT="PROJECT_TYPE=web"
    else
      PROJECT_TYPE_RESULT="PROJECT_TYPE=node"
    fi
  elif [ "$_HAS_PY" = "yes" ]; then
    PROJECT_TYPE_RESULT="PROJECT_TYPE=python"
  elif [ "$_HAS_GO" = "yes" ]; then
    PROJECT_TYPE_RESULT="PROJECT_TYPE=go"
  elif [ "$_HAS_TF" = "yes" ]; then
    PROJECT_TYPE_RESULT="PROJECT_TYPE=infra"
  else
    # Check for devops (YAML + Shell, no app language)
    _HAS_YAML=$(echo "$_SCC" | grep -qi "YAML" && echo "yes" || echo "no")
    _HAS_SHELL=$(echo "$_SCC" | grep -qi "Shell\|BASH" && echo "yes" || echo "no")
    if [ "$_HAS_YAML" = "yes" ] || [ "$_HAS_SHELL" = "yes" ]; then
      PROJECT_TYPE_RESULT="PROJECT_TYPE=devops"
    else
      PROJECT_TYPE_RESULT="PROJECT_TYPE=general"
    fi
  fi
else
  PROJECT_TYPE_RESULT="PROJECT_TYPE=general"
fi

# === Service detection (Supabase, etc.) ===
HAS_SUPABASE="no"
# Check for Supabase MCP server in .mcp.json
if [ -f .mcp.json ] && grep -qi '"supabase"' .mcp.json 2>/dev/null; then
  HAS_SUPABASE="yes"
fi
# Check for supabase directory (migrations, client code)
if [ -d supabase ] || find . -maxdepth 3 -type d -name supabase -print -quit 2>/dev/null | grep -q .; then
  HAS_SUPABASE="yes"
fi

# Read using-rkstack content
using_rkstack_content=$(cat "${PLUGIN_ROOT}/skills/using-rkstack/SKILL.md" 2>&1 || echo "Error reading using-rkstack skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass — orders of magnitude
# faster than a character-by-character loop.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_rkstack_escaped=$(escape_for_json "$using_rkstack_content")

# Build session context — prepend bootstrap results if available
bootstrap_prefix=""
if [ -n "$RKSTACK_BOOTSTRAP_RESULT" ]; then
  bootstrap_escaped=$(escape_for_json "$RKSTACK_BOOTSTRAP_RESULT")
  bootstrap_prefix="${bootstrap_escaped}\n"
fi
if [ -n "$BROWSE_BOOTSTRAP_RESULT" ]; then
  browse_escaped=$(escape_for_json "$BROWSE_BOOTSTRAP_RESULT")
  bootstrap_prefix="${bootstrap_prefix}${browse_escaped}\n"
fi
if [ -n "$PROJECT_TYPE_RESULT" ]; then
  ptype_escaped=$(escape_for_json "$PROJECT_TYPE_RESULT")
  bootstrap_prefix="${bootstrap_prefix}${ptype_escaped}\n"
fi
if [ "$HAS_SUPABASE" = "yes" ]; then
  bootstrap_prefix="${bootstrap_prefix}HAS_SUPABASE=yes\n"
fi
if [ -n "$bootstrap_prefix" ]; then
  bootstrap_prefix="${bootstrap_prefix}\n"
fi
session_context="${bootstrap_prefix}<EXTREMELY_IMPORTANT>\nYou have rkstack skills.\n\n**Below is the full content of your 'rkstack:using-rkstack' skill — your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_rkstack_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context.
# Claude Code hooks expect hookSpecificOutput.additionalContext.
# Claude Code reads BOTH fields without deduplication, so we must only
# emit the field consumed by the current platform to avoid double injection.
#
# Uses printf instead of heredoc (cat <<EOF) to work around a bash 5.3+
# bug where heredoc variable expansion hangs when content exceeds ~512 bytes.
# See: https://github.com/obra/superpowers/issues/571
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT) — emit additional_context
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT — emit only hookSpecificOutput
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Other platforms — emit additional_context as fallback
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
