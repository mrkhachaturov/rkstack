#!/usr/bin/env bash
# gen-skill-docs — generate SKILL.md from .tmpl templates
#
# Usage:
#   ./scripts/gen-skill-docs              # generate all
#   ./scripts/gen-skill-docs --check      # verify up to date (exit 1 if stale)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SCRIPTS_DIR="${REPO_ROOT}/scripts"
SKILLS_DIR="${REPO_ROOT}/skills"

# Load placeholder content
PREAMBLE=$(cat "${SCRIPTS_DIR}/preamble.md")

ASK_FORMAT=$(cat <<'ASKEOF'
### AskUserQuestion format

When asking the user a question, follow this structure:

1. **Re-ground** (1-2 sentences): project name, branch, what you're working on
2. **Simplify** (plain English): what the problem is, no jargon, use analogies if helpful
3. **Recommend** (with reasoning): always prefer the complete option
   - Include `Completeness: X/10` for each option (10 = all edges, 7 = happy path, 3 = shortcut)
   - Show effort: `(human: ~X days / CC: ~Y min)`
4. **Options** (lettered): A, B, C — one decision per question, never batch multiple decisions
ASKEOF
)

ESCALATION=$(cat <<'ESCEOF'
### Escalation protocol

After 3 failed attempts at any operation, stop and report:

```
STATUS: BLOCKED
REASON: [1-2 sentences describing what failed]
ATTEMPTED: [what was tried, max 3 items]
RECOMMENDATION: [concrete next step for the user]
```

Do not retry indefinitely. Do not work around the problem silently.
ESCEOF
)

COMPLETENESS=$(cat <<'COMPEOF'
### Completeness principle

AI makes the marginal cost of completeness near-zero. Always prefer the full
implementation over shortcuts:

- Completeness 10/10: all edge cases, error handling, tests, documentation
- Completeness 7/10: happy path works, some edge cases skipped
- Completeness 3/10: proof of concept, significant work deferred

When presenting options, show completeness scores and effort comparison:
`(human: ~X days / CC: ~Y min)`. Recommend the most complete option.
COMPEOF
)

# Process one template
process_template() {
    local tmpl="$1"
    local output="${tmpl%.tmpl}"
    local mode="${2:-generate}"

    # Write placeholder files to temp dir for awk include
    local tmpdir
    tmpdir=$(mktemp -d)
    printf '%s' "$PREAMBLE" > "${tmpdir}/PREAMBLE"
    printf '%s' "$ASK_FORMAT" > "${tmpdir}/ASK_FORMAT"
    printf '%s' "$ESCALATION" > "${tmpdir}/ESCALATION"
    printf '%s' "$COMPLETENESS" > "${tmpdir}/COMPLETENESS"

    # Use awk to replace {{PLACEHOLDER}} with file contents
    # This avoids bash parameter substitution issues with &&, ||, etc.
    local result
    result=$(awk -v dir="$tmpdir" '{
        while (match($0, /\{\{([A-Z_]+)\}\}/, m)) {
            file = dir "/" m[1]
            replacement = ""
            while ((getline line < file) > 0) {
                if (replacement != "") replacement = replacement "\n"
                replacement = replacement line
            }
            close(file)
            $0 = substr($0, 1, RSTART-1) replacement substr($0, RSTART+RLENGTH)
        }
        print
    }' "$tmpl")

    rm -rf "$tmpdir"

    if [ "$mode" = "--check" ]; then
        if [ -f "$output" ]; then
            local existing
            existing=$(cat "$output")
            if [ "$result" != "$existing" ]; then
                echo "STALE: $output"
                return 1
            fi
        else
            echo "MISSING: $output"
            return 1
        fi
    else
        printf '%s\n' "$result" > "$output"
        echo "Generated: $output"
    fi
}

# Find and process all templates
check_mode=false
if [ "${1:-}" = "--check" ]; then
    check_mode=true
fi

stale=0
for tmpl in $(find "$SKILLS_DIR" -name "*.tmpl" -type f | sort); do
    if $check_mode; then
        process_template "$tmpl" "--check" || ((stale++))
    else
        process_template "$tmpl"
    fi
done

# Also process root SKILL.md.tmpl if exists
if [ -f "${REPO_ROOT}/SKILL.md.tmpl" ]; then
    if $check_mode; then
        process_template "${REPO_ROOT}/SKILL.md.tmpl" "--check" || ((stale++))
    else
        process_template "${REPO_ROOT}/SKILL.md.tmpl"
    fi
fi

if $check_mode; then
    if [ "$stale" -gt 0 ]; then
        echo "ERROR: $stale file(s) out of date. Run: just build"
        exit 1
    else
        echo "OK: all generated files up to date"
    fi
fi
